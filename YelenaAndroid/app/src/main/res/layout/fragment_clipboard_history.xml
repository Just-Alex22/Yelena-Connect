<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_view">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="@string/btn_back"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clipboard_title"
            android:textColor="@color/text_primary"
            android:textSize="17sp" android:textStyle="bold"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Portapapeles actual — editable -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clipboard_current"
            android:textAppearance="@style/TextAppearance.Yelena.Caption"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Yelena.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">
                <EditText
                    android:id="@+id/etCurrentClipboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Sin contenido"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_disabled"
                    android:textSize="14sp"
                    android:background="@null"
                    android:maxLines="4"
                    android:inputType="textMultiLine"/>
                <ImageButton
                    android:id="@+id/btnSendCurrent"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/accent_green"
                    android:contentDescription="@string/btn_send"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Historial -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/history_label"
        android:textAppearance="@style/TextAppearance.Yelena.Caption"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_history"
        android:textColor="@color/text_disabled"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/historyList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"/>
    </ScrollView>

</LinearLayout>
