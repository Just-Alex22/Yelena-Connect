<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="52dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@color/bg_card" android:padding="14dp" android:layout_marginBottom="4dp">
    <TextView android:id="@+id/tvAppName" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="@color/text_primary" android:textSize="14sp"/>
    <ImageView android:layout_width="18dp" android:layout_height="18dp"
        android:src="@drawable/ic_arrow_back" android:rotation="180"
        android:tint="@color/text_disabled" android:contentDescription=""/>
</LinearLayout>
